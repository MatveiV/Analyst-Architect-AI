# LLM Provider (выбери один: anthropic | openai | proxyapi | openrouter | ollama)
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
PROXYAPI_KEY=your_proxyapi_key_here
PROXYAPI_BASE_URL=https://api.proxyapi.ru/anthropic
PROXYAPI_MODEL=claude-sonnet-4-20250514
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_ROUTE=openrouter/free
LLM_PROVIDER=anthropic

# ── Эпик C: локальные LLM через Ollama (данные не покидают корпоративный контур) ──
# Ключ не требуется. Если Ollama поднята вашим docker-compose (profile local-llm):
OLLAMA_BASE_URL=http://ollama:11434/v1
# Если Ollama уже установлена на хосте (ноутбук аналитика) — не поднимайте профиль local-llm,
# а укажите один из вариантов ниже вместо строки выше:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1   # Windows/Mac
#   OLLAMA_BASE_URL=http://172.17.0.1:11434/v1              # Linux
OLLAMA_MODEL=qwen2.5:14b-instruct
# Если true — система не делает НИ ОДНОГО внешнего сетевого вызова (ни LLM, ни рендер диаграмм):
# при недоступности локальных сервисов возвращается явная ошибка вместо тихого ухода наружу.
ENFORCE_LOCAL_ONLY=false

# ── Эпик A1: локальный рендер диаграмм (Kroki) вместо plantuml.com/mermaid.live ──
DIAGRAM_RENDERER_URL=http://kroki:8000
DIAGRAM_RENDERER_TIMEOUT=10

# Database
DATABASE_URL=sqlite:///./data/analyst_architect_ai.db
# Для PostgreSQL: postgresql://user:password@localhost:5432/analyst_architect_ai

# Auth / JWT (обязательно сгенерировать перед продакшн: openssl rand -hex 32)
APP_SECRET_KEY=change_me_in_production

# App settings
MAX_DOCUMENT_LENGTH=30000
RAG_TOP_K=5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
